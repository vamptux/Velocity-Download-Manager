{
  "name": "velocity-download-manager",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:windows": "bun run tauri build --bundles nsis",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint:src": "oxlint src/ --deny-warnings",
    "lint:extensions": "oxlint extensions/ --deny-warnings",
    "lint": "bun run lint:src && bun run lint:extensions",
    "test:extension": "bun -e \"import { spawnSync } from 'node:child_process'; import { existsSync } from 'node:fs'; const path = './extensions/vdm-catcher/shared/download-rules.test.js'; if (!existsSync(path)) { console.log('No extension tests found; skipping.'); process.exit(0); } const result = spawnSync(process.execPath, ['test', path], { stdio: 'inherit' }); process.exit(result.status ?? 1);\"",
    "check:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --target-dir src-tauri/target-clippy --all-targets --all-features -- -D warnings",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --target-dir src-tauri/target-test",
    "validate": "bun run lint && bun run build && bun run test:extension && bun run test:rust && bun run check:rust",
    "audit:js": "bun audit"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "~2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "^10.4.27",
    "oxlint": "1.55.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "8.0.0"
  }
}
